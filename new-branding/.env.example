# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (SMTP via Nodemailer)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@example.com
EMAIL_DEV_TO=dev-team@example.com

# Sales contact email (receives contact form submissions)
SALES_CONTACT_EMAIL=sales@example.com

# Public site URL (used in email templates for links and logos)
PUBLIC_SITE_URL=https://utexo.com
